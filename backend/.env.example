# Copy to .env — never commit .env
# Quote passwords that contain special characters: SUPABASE_DB_PASSWORD='your@password'

PORT=8081
SUPABASE_URL=https://zqvlzrrumfewlyqipphz.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...

# Option A: direct SQLAlchemy URL (preferred for Python)
# DATABASE_URL=postgresql://postgres.zqvlzrrumfewlyqipphz:password@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres?sslmode=require

# Option B: JDBC URL (converted automatically)
SUPABASE_DB_URL="jdbc:postgresql://aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres?sslmode=require&prepareThreshold=0"
SUPABASE_DB_USER=postgres.zqvlzrrumfewlyqipphz
SUPABASE_DB_PASSWORD='your-database-password'

# Scheduler (separate process — ./run_scheduler.sh)
SCHEDULER_ENABLED=true
SCHEDULER_RUN_ON_START=false
SCRAPER_INTERVAL_MINUTES=60
# 30 = every 30 min | 60 = hourly | 120 = every 2 hours

SCRAPER_POLITE_DELAY_MS=2500
SCRAPER_TIMEOUT_MS=15000
CORS_ORIGINS=*
